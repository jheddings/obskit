{
    "name": "obskit",
    "version": "1.5.0",
    "description": "Utilities and helpers for building Obsidian plugins.",
    "keywords": [
        "obsidian"
    ],
    "homepage": "https://github.com/jheddings/obskit#readme",
    "bugs": {
        "url": "https://github.com/jheddings/obskit/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jheddings/obskit.git"
    },
    "license": "MIT",
    "author": "jheddings",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "prepare": "husky",
        "build": "tsc",
        "dev": "tsc --watch",
        "test": "jest"
    },
    "peerDependencies": {
        "obsidian": "^1.12.3"
    },
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "@types/node": "^24.12.2",
        "@typescript-eslint/eslint-plugin": "^8.58.2",
        "@typescript-eslint/parser": "^8.58.2",
        "eslint": "^10.2.0",
        "husky": "^9.1.7",
        "jest": "^30.3.0",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.3",
        "ts-jest": "^29.4.9",
        "tslib": "2.8.1",
        "typescript": "^5.9.3"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,json,css,scss,md}": [
            "prettier --check",
            "eslint"
        ]
    }
}
