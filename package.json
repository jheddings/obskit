{
    "name": "obskit",
    "version": "2.0.0",
    "description": "Utilities and helpers for building Obsidian plugins.",
    "keywords": [
        "obsidian"
    ],
    "homepage": "https://github.com/jheddings/obskit#readme",
    "bugs": {
        "url": "https://github.com/jheddings/obskit/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jheddings/obskit.git"
    },
    "license": "MIT",
    "author": "jheddings",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "prepare": "husky",
        "build": "tsc",
        "dev": "tsc --watch",
        "test": "jest"
    },
    "peerDependencies": {
        "obsidian": "^1.13.1"
    },
    "engines": {
        "node": ">=24.18.0"
    },
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "@types/node": "^24.13.3",
        "@typescript-eslint/eslint-plugin": "^8.65.0",
        "@typescript-eslint/parser": "^8.65.0",
        "eslint": "^10.7.0",
        "husky": "^9.1.7",
        "jest": "^30.4.2",
        "lint-staged": "^17.1.0",
        "prettier": "^3.9.5",
        "ts-jest": "^29.4.11",
        "tslib": "2.8.1",
        "typescript": "^6.0.3"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,json,css,scss,md}": [
            "prettier --check",
            "eslint"
        ]
    }
}
