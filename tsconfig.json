{
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./dist",

        "module": "ESNext",
        "target": "ES2020",
        "moduleResolution": "bundler",
        "types": [],

        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,

        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,

        "strict": true,
        "jsx": "react-jsx",
        "isolatedModules": true,
        "moduleDetection": "force",
        "skipLibCheck": true
    },
    "exclude": [
        "tmp/**/*",
        "node_modules/**/*",
        "dist/**/*",
        "plugin/**/*",
        "tests/**/*",
        "jest.config.ts"
    ]
}
